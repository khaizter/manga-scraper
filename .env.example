# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Pipeline store: json (local files) or firestore
# firestore = manga data + pipeline queue in Firestore
# json      = manga data + queue in data/pipeline/ (local dev)
PIPELINE_STORE=firestore

# --- Firebase Admin SDK (required when PIPELINE_STORE=firestore) ---
# 1. Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate new private key" and save the JSON file locally
# 3. Point one of the credential paths below to that file

# Standard Google env var (recommended) — host path for local CLI
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-firebase-adminsdk.json

# Optional alias used by this project (same file as above)
FIREBASE_CREDENTIALS_PATH=C:\path\to\your-firebase-adminsdk.json

# Docker: path inside the container (docker-compose mounts ./credentials -> /app/credentials)
FIREBASE_CREDENTIALS_CONTAINER_PATH=/app/credentials/your-firebase-adminsdk.json

# Your Firebase project ID (from Firebase Console > Project Settings > General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional alias (used if FIREBASE_PROJECT_ID is not set)
GOOGLE_CLOUD_PROJECT=your-firebase-project-id

# Firebase Storage bucket (defaults to {FIREBASE_PROJECT_ID}.firebasestorage.app)
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
